{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "bash railway/build.sh",
    "watchPatterns": [
      "/backend/**",
      "/frontend/**",
      "/railway.json",
      "/railway/**"
    ]
  },
  "deploy": {
    "startCommand": "bash railway/start.sh",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
